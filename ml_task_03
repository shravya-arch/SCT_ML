def main():
    print("=" * 55)
    print("  SVM CAT vs DOG CLASSIFIER — TASK 03")
    print("  SkillCraft Technology Internship")
    print("=" * 55)

    # ─── CHOOSE YOUR DATASET ────────────────────────────────
    # Uncomment ONE of the three options below:

    # ✅ OPTION 1 — Best quality, auto-downloads (recommended)
    # images, labels = load_from_tensorflow_datasets(N_SAMPLES)

    # ✅ OPTION 2 — Kaggle dataset (download manually first)
    # images, labels = load_from_kaggle_folder("./dogs-vs-cats/train")

    # ✅ OPTION 3 — Instant demo (no download needed)
    images, labels = generate_synthetic_demo(200)

    # ─── PREPROCESS ─────────────────────────────────────────
    X = preprocess_images(images)
    y = labels

    # ─── TRAIN / TEST SPLIT ──────────────────────────────────
    from sklearn.model_selection import train_test_split
    X_train, X_test, y_train, y_test, idx_train, idx_test = train_test_split(
        X, y, np.arange(len(y)),
        test_size=TEST_SPLIT, random_state=RANDOM_SEED, stratify=y
    )
    raw_images_test = images[idx_test]

    print(f"\n📐 Dataset split:")
    print(f"   Train: {len(X_train)} samples | Test: {len(X_test)} samples")

    # ─── TRAIN ───────────────────────────────────────────────
    model = train_svm(X_train, y_train, use_grid_search=False)

    # ─── EVALUATE ────────────────────────────────────────────
    acc, cm = evaluate_and_plot(model, X_test, y_test, raw_images_test)

    print("\n✅ ALL DONE!")
    print(f"   Final Accuracy: {acc*100:.2f}%")
    print("   Output files: results_metrics.png, results_predictions.png, results_pca.png")
    print("=" * 55)


if __name__ == "__main__":
    main()
